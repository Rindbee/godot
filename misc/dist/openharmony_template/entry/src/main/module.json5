{
  "module": {
    "name": "entry",
    "type": "entry",
    "description": "$string:module_desc",
    "mainElement": "EntryAbility",
    "deviceTypes": [
      "phone",
      "tablet",
      "2in1"
    ],
    "deliveryWithInstall": true,
    "installationFree": false,
    "pages": "$profile:main_pages",
    "requestPermissions": [
      {
        "name": "ohos.permission.ACCELEROMETER"
      },
      {
        "name": "ohos.permission.ACCESS_BIOMETRIC"
      },
      {
        "name": "ohos.permission.ACCESS_CAR_DISTRIBUTED_ENGINE"
      },
      {
        "name": "ohos.permission.ACCESS_CERT_MANAGER"
      },
      {
        "name": "ohos.permission.ACCESS_EXTENSIONAL_DEVICE_DRIVER"
      },
      {
        "name": "ohos.permission.ACCESS_NOTIFICATION_POLICY"
      },
      {
        "name": "ohos.permission.ACCESS_SERVICE_NAVIGATION_INFO"
      },
      {
        "name": "ohos.permission.ALLOW_COREDUMP"
      },
      {
        "name": "ohos.permission.BACKGROUND_MANAGER_POWER_SAVE_MODE"
      },
      {
        "name": "ohos.permission.CLEAN_BACKGROUND_PROCESSES"
      },
      {
        "name": "ohos.permission.COMMONEVENT_STICKY"
      },
      {
        "name": "ohos.permission.CONNECT_OBJECTEDITOR_EXTENSION"
      },
      {
        "name": "ohos.permission.CUSTOMIZE_MENU_ICON"
      },
      {
        "name": "ohos.permission.DETECT_GESTURE"
      },
      {
        "name": "ohos.permission.DISCOVER_BLUETOOTH"
      },
      {
        "name": "ohos.permission.FILE_ACCESS_PERSIST"
      },
      {
        "name": "ohos.permission.GET_BUNDLE_INFO"
      },
      {
        "name": "ohos.permission.GET_DONOTDISTURB_STATE"
      },
      {
        "name": "ohos.permission.GET_FILE_ICON"
      },
      {
        "name": "ohos.permission.GET_NETWORK_INFO"
      },
      {
        "name": "ohos.permission.GET_WIFI_INFO"
      },
      {
        "name": "ohos.permission.GYROSCOPE"
      },
      {
        "name": "ohos.permission.HDR_BRIGHTNESS"
      },
      {
        "name": "ohos.permission.INHERIT_PARENT_PERMISSION"
      },
      {
        "name": "ohos.permission.INPUT_KEYBOARD_CONTROLLER"
      },
      {
        "name": "ohos.permission.INTERNET"
      },
      {
        "name": "ohos.permission.KEEP_BACKGROUND_RUNNING"
      },
      {
        "name": "ohos.permission.LOCK_WINDOW_CURSOR"
      },
      {
        "name": "ohos.permission.MANAGE_INPUT_INFRARED_EMITTER"
      },
      {
        "name": "ohos.permission.NDK_START_SELF_UI_ABILITY"
      },
      {
        "name": "ohos.permission.NFC_CARD_EMULATION"
      },
      {
        "name": "ohos.permission.NFC_TAG"
      },
      {
        "name": "ohos.permission.PREPARE_APP_TERMINATE"
      },
      {
        "name": "ohos.permission.PRINT"
      },
      {
        "name": "ohos.permission.PRIVACY_WINDOW"
      },
      {
        "name": "ohos.permission.PROTECT_SCREEN_LOCK_DATA"
      },
      {
        "name": "ohos.permission.PUBLISH_AGENT_REMINDER"
      },
      {
        "name": "ohos.permission.READ_ACCOUNT_LOGIN_STATE"
      },
      {
        "name": "ohos.permission.READ_CLOUD_SYNC_CONFIG"
      },
      {
        "name": "ohos.permission.RUN_DYN_CODE"
      },
      {
        "name": "ohos.permission.SET_ABILITY_INSTANCE_INFO"
      },
      {
        "name": "ohos.permission.SET_NETWORK_INFO"
      },
      {
        "name": "ohos.permission.SET_WIFI_INFO"
      },
      {
        "name": "ohos.permission.SET_WINDOW_TRANSPARENT"
      },
      {
        "name": "ohos.permission.START_WINDOW_BELOW_LOCK_SCREEN"
      },
      {
        "name": "ohos.permission.STORE_PERSISTENT_DATA"
      },
      {
        "name": "ohos.permission.TIMEOUT_SCREENOFF_DISABLE_LOCK"
      },
      {
        "name": "ohos.permission.USE_BLUETOOTH"
      },
      {
        "name": "ohos.permission.VIBRATE"
      },
      {
        "name": "ohos.permission.WINDOW_TOPMOST"
      },
      {
        "name": "ohos.permission.ACCESS_BLUETOOTH",
        "reason": "$string:ACCESS_BLUETOOTH_reason",
        "usedScene": {
          "abilities": [
            "EntryAbility"
          ],
          "when": "always"
        }
      },
      {
        "name": "ohos.permission.ACCESS_NEARLINK",
        "reason": "$string:ACCESS_NEARLINK_reason",
        "usedScene": {
          "abilities": [
            "EntryAbility"
          ],
          "when": "always"
        }
      },
      {
        "name": "ohos.permission.ACTIVITY_MOTION",
        "reason": "$string:ACTIVITY_MOTION_reason",
        "usedScene": {
          "abilities": [
            "EntryAbility"
          ],
          "when": "always"
        }
      },
      {
        "name": "ohos.permission.APPROXIMATELY_LOCATION",
        "reason": "$string:APPROXIMATELY_LOCATION_reason",
        "usedScene": {
          "abilities": [
            "EntryAbility"
          ],
          "when": "always"
        }
      },
      {
        "name": "ohos.permission.APP_TRACKING_CONSENT",
        "reason": "$string:APP_TRACKING_CONSENT_reason",
        "usedScene": {
          "abilities": [
            "EntryAbility"
          ],
          "when": "always"
        }
      },
      {
        "name": "ohos.permission.CAMERA",
        "reason": "$string:CAMERA_reason",
        "usedScene": {
          "abilities": [
            "EntryAbility"
          ],
          "when": "always"
        }
      },
      {
        "name": "ohos.permission.CUSTOM_SCREEN_CAPTURE",
        "reason": "$string:CUSTOM_SCREEN_CAPTURE_reason",
        "usedScene": {
          "abilities": [
            "EntryAbility"
          ],
          "when": "always"
        }
      },
      {
        "name": "ohos.permission.DISTRIBUTED_DATASYNC",
        "reason": "$string:DISTRIBUTED_DATASYNC_reason",
        "usedScene": {
          "abilities": [
            "EntryAbility"
          ],
          "when": "always"
        }
      },
      {
        "name": "ohos.permission.LOCATION",
        "reason": "$string:LOCATION_reason",
        "usedScene": {
          "abilities": [
            "EntryAbility"
          ],
          "when": "always"
        }
      },
      {
        "name": "ohos.permission.LOCATION_IN_BACKGROUND",
        "reason": "$string:LOCATION_IN_BACKGROUND_reason",
        "usedScene": {
          "abilities": [
            "EntryAbility"
          ],
          "when": "always"
        }
      },
      {
        "name": "ohos.permission.MEDIA_LOCATION",
        "reason": "$string:MEDIA_LOCATION_reason",
        "usedScene": {
          "abilities": [
            "EntryAbility"
          ],
          "when": "always"
        }
      },
      {
        "name": "ohos.permission.MICROPHONE",
        "reason": "$string:MICROPHONE_reason",
        "usedScene": {
          "abilities": [
            "EntryAbility"
          ],
          "when": "always"
        }
      },
      {
        "name": "ohos.permission.READ_CALENDAR",
        "reason": "$string:READ_CALENDAR_reason",
        "usedScene": {
          "abilities": [
            "EntryAbility"
          ],
          "when": "always"
        }
      },
      {
        "name": "ohos.permission.READ_HEALTH_DATA",
        "reason": "$string:READ_HEALTH_DATA_reason",
        "usedScene": {
          "abilities": [
            "EntryAbility"
          ],
          "when": "always"
        }
      },
      {
        "name": "ohos.permission.READ_WRITE_DOCUMENTS_DIRECTORY",
        "reason": "$string:READ_WRITE_DOCUMENTS_DIRECTORY_reason",
        "usedScene": {
          "abilities": [
            "EntryAbility"
          ],
          "when": "always"
        }
      },
      {
        "name": "ohos.permission.READ_WRITE_DOWNLOAD_DIRECTORY",
        "reason": "$string:READ_WRITE_DOWNLOAD_DIRECTORY_reason",
        "usedScene": {
          "abilities": [
            "EntryAbility"
          ],
          "when": "always"
        }
      },
      {
        "name": "ohos.permission.WRITE_CALENDAR",
        "reason": "$string:WRITE_CALENDAR_reason",
        "usedScene": {
          "abilities": [
            "EntryAbility"
          ],
          "when": "always"
        }
      }
    ],
    "abilities": [
      {
        "name": "EntryAbility",
        "srcEntry": "./ets/entryability/EntryAbility.ets",
        "description": "$string:EntryAbility_desc",
        "icon": "$media:layered_image",
        "label": "$string:EntryAbility_label",
        "startWindowIcon": "$media:foreground",
        "startWindowBackground": "$color:start_window_background",
        "exported": true,
        "orientation": "$string:orientation",
        "skills": [
          {
            "entities": [
              "entity.system.home"
            ],
            "actions": [
              "action.system.home"
            ]
          }
        ]
      }
    ],
    "extensionAbilities": [
      {
        "name": "EntryBackupAbility",
        "srcEntry": "./ets/entrybackupability/EntryBackupAbility.ets",
        "type": "backup",
        "exported": false,
        "metadata": [
          {
            "name": "ohos.extension.backup",
            "resource": "$profile:backup_config"
          }
        ]
      }
    ],
    "compressNativeLibs": true
  }
}
